---
import { verifyAdminCookie } from '../../lib/adminAuth';
import { getAllImages, formatImageDate } from '../../lib/db';
import AdminLayout from '../../layouts/AdminLayout.astro';

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const env = (Astro.locals as any).runtime?.env;
if (!env || !await verifyAdminCookie(Astro.request, env)) {
  return Astro.redirect('/admin');
}

const filter = (Astro.url.searchParams.get('type') ?? 'all') as 'all' | 'photo' | 'poster';
const allImages = await getAllImages(env);
const images = filter === 'all' ? allImages : allImages.filter(img => img.type === filter);
---

<AdminLayout title="Media" activeNav="photos">
  <main class="max-w-7xl mx-auto px-6 py-10">

    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-xl font-semibold text-white mb-1">Media</h1>
        <p class="text-sm text-zinc-500">{allImages.length} items total</p>
      </div>
      <a href="/admin/upload" class="bg-white text-zinc-950 font-semibold rounded-xl px-5 py-2.5 text-sm hover:bg-zinc-100 transition-colors">
        + Upload
      </a>
    </div>

    <!-- Filter tabs -->
    <div class="flex gap-1 mb-8 bg-zinc-900 border border-zinc-800 rounded-xl p-1 w-fit">
      {(['all', 'photo', 'poster'] as const).map(tab => (
        <a
          href={`/admin/photos${tab === 'all' ? '' : `?type=${tab}`}`}
          class={`px-4 py-1.5 rounded-lg text-sm font-medium transition-colors ${filter === tab ? 'bg-zinc-700 text-white' : 'text-zinc-500 hover:text-zinc-300'}`}
        >
          {tab === 'all'
            ? `All (${allImages.length})`
            : tab === 'photo'
              ? `Photos (${allImages.filter(i => i.type === 'photo').length})`
              : `Posters (${allImages.filter(i => i.type === 'poster').length})`}
        </a>
      ))}
    </div>

    {images.length === 0 ? (
      <p class="text-zinc-500 text-sm">No media found.</p>
    ) : (
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-8 gap-3">
        {images.map(image => (
          <a href={`/admin/photos/${image.id}`} class="group block">
            <div class="aspect-square bg-zinc-900 rounded-lg overflow-hidden mb-1.5 relative">
              <img
                src={`/cdn/${image.r2_key}`}
                alt={image.caption || ''}
                class="w-full h-full object-cover group-hover:opacity-75 transition-opacity"
                loading="lazy"
              />
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/40">
                <div class="bg-zinc-900/90 border border-zinc-700 rounded-xl px-3 py-2 flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white flex-shrink-0">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                  </svg>
                  <span class="text-white text-xs font-medium">Edit</span>
                </div>
              </div>
            </div>
            <p class="text-zinc-500 text-xs truncate">{formatImageDate(image)}</p>
            {image.caption && <p class="text-zinc-400 text-xs truncate">{image.caption}</p>}
          </a>
        ))}
      </div>
    )}

  </main>
</AdminLayout>
