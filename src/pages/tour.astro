---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchTourDates } from '../lib/sheets';

const allEvents = await fetchTourDates();
const events = allEvents.filter((event) => event.confirmed.toUpperCase() === 'Y');
---

<style>
  .tour-gradient {
    background: linear-gradient(to bottom, rgba(9,9,11,0.75) 0%, rgba(9,9,11,0.25) 8%, rgba(9,9,11,0.25) 28vw, rgba(9,9,11,0.85) 35vw, #09090b 37.6vw);
  }
  @media (max-width: 767px) {
    .tour-gradient {
      background: linear-gradient(to bottom, rgba(9,9,11,0.5) 0%, rgba(9,9,11,0.1) 5%, rgba(9,9,11,0.1) 35%, rgba(9,9,11,0.85) 52%, #09090b 62%);
    }
  }
</style>

<BaseLayout title="Live Shows — Twinkle Brothers" description="Upcoming Twinkle Brothers live shows and performances.">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(events.map(event => ({
    "@context": "https://schema.org",
    "@type": "MusicEvent",
    "name": event.eventName,
    "startDate": event.startDate,
    "location": {
      "@type": "Place",
      "name": event.location || "TBC",
      "address": event.location || "TBC"
    },
    "performer": {
      "@type": "MusicGroup",
      "name": "Twinkle Brothers",
      "url": "https://twinklebrothersmusic.com"
    },
    "organizer": {
      "@type": "MusicGroup",
      "name": "Twinkle Brothers"
    },
    "eventStatus": "https://schema.org/EventScheduled",
    "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
    ...(event.ticketUrl ? { "url": event.ticketUrl, "offers": { "@type": "Offer", "url": event.ticketUrl, "availability": "https://schema.org/InStock" } } : {})
  })))} />
  <div class="relative min-h-screen">
    <div class="absolute inset-0">
      <img
        src="/tour-bg.jpg"
        alt=""
        class="absolute top-0 left-0 w-full h-[340px] object-cover object-top md:h-auto md:object-none"
      />
    </div>
    <div class="absolute inset-0 tour-gradient"></div>
    <h1 class="relative z-10 font-display text-5xl md:text-7xl tracking-widest uppercase text-white pt-56 md:pt-20 pb-0 max-w-4xl mx-auto px-6">Live Shows</h1>
    <div class="relative z-10 max-w-4xl mx-auto px-6 pb-64 mt-4 md:mt-[21vw]">
      {events.length === 0 ? (
        <p class="text-zinc-400">No upcoming dates at this time. Check back soon.</p>
      ) : (
        <div class="space-y-2">
          {events.map((event) => (
            <div class="group flex flex-col md:flex-row md:items-baseline gap-1 md:gap-6 py-6 px-4 -mx-4 border border-white/10 hover:border-accent/30 bg-white/5 hover:bg-white/10 backdrop-blur-md transition-colors rounded-lg">
              <div class="font-display text-8xl text-white/15 group-hover:text-accent/25 transition-colors leading-none shrink-0 w-36 text-right hidden md:block">
                {event.date.split(' ')[0]}
              </div>
              <div class="flex-1 flex flex-col md:flex-row md:items-baseline md:justify-between gap-3">
                <div>
                  <div class="font-display text-2xl md:text-4xl tracking-wider uppercase text-white leading-tight drop-shadow-lg">{event.eventName}</div>
                  <div class="flex items-center gap-3 mt-1">
                    <span class="text-accent text-sm font-medium">{event.date}</span>
                    {event.location && <span class="text-zinc-300 text-sm">— {event.location}</span>}
                  </div>
                </div>
                {event.paidShow.toUpperCase() === 'Y' && event.ticketUrl && (
                  <a
                    href={event.ticketUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="shrink-0 border border-accent text-accent text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded hover:bg-accent hover:text-zinc-950 transition-colors self-start md:self-auto"
                  >
                    Tickets
                  </a>
                )}
                {event.paidShow.toUpperCase() === 'N' && (
                  event.ticketUrl ? (
                    <a
                      href={event.ticketUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="shrink-0 border border-white/40 text-white/70 text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded hover:border-white hover:text-white transition-colors self-start md:self-auto"
                    >
                      Free
                    </a>
                  ) : (
                    <span class="shrink-0 border border-white/40 text-white/70 text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded self-start md:self-auto">
                      Free
                    </span>
                  )
                )}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>
