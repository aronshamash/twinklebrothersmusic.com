---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getImageById } from '../lib/db';
import { fetchTourDates } from '../lib/sheets';
import { thumbKey } from '../lib/thumbKey';

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const env = (Astro.locals as any).runtime?.env;

const featuredPhotoIds = [
  'e7f2f66d-27cf-403e-9f74-d9e59df7654e',
  '07c09655-9ff5-49bc-a261-33f9377dd0db',
  'c46f6b46-8f85-4af3-894c-e4496ddac551',
  'cf34c387-8c3f-49dc-9011-3245087c4ef2',
  '7b1d6f46-d607-42d1-8e55-fbedff4e8c2b',
  'c887cea4-4657-4abf-8769-3d53d7915a68',
];

const [heroPhoto, tourPhoto, storyPhoto, allEvents, ...featuredPhotosRaw] = await Promise.all([
  env ? getImageById(env, '2a91e2da-45e4-4d9b-af64-24b7dc182488') : null,
  env ? getImageById(env, '0559bf3e-2158-47d5-9126-948aee9ee894') : null,
  env ? getImageById(env, '0015c01f-b832-482e-865f-2426f3cc7a5d') : null,
  fetchTourDates(),
  ...featuredPhotoIds.map(id => env ? getImageById(env, id) : null),
]);

const upcomingShows = allEvents
  .filter((e: { confirmed: string }) => e.confirmed.toUpperCase() === 'Y')
  .slice(0, 3);

const featuredPhotos = featuredPhotosRaw.filter(Boolean);
---

<BaseLayout title="Twinkle Brothers — Reggae Legends Since 1962">

  <!-- Hero -->
  <section class="relative min-h-screen flex flex-col justify-end overflow-hidden">
    {heroPhoto ? (
      <img
        src={`/cdn/${heroPhoto.r2_key}`}
        alt=""
        class="absolute inset-0 w-full h-full object-cover object-[center_20%]"
      />
    ) : (
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 35%, rgba(50,35,5,1) 0%, rgba(25,15,2,0.9) 40%, #09090b 70%);"></div>
    )}
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(9,9,11,0.65) 0%, rgba(9,9,11,0.08) 22%, rgba(9,9,11,0.08) 42%, rgba(9,9,11,0.82) 64%, #09090b 100%)"></div>
    <div class="relative z-10 px-6 max-w-4xl mx-auto w-full pb-16">
      <p class="text-xs tracking-[0.3em] uppercase font-semibold text-accent mb-4 opacity-90">Est. 1962 · Falmouth, Jamaica</p>
      <h1 class="font-display text-6xl md:text-8xl lg:text-9xl tracking-widest uppercase text-white mb-6 leading-none">
        Twinkle<br>Brothers
      </h1>
      <p class="text-zinc-300 text-lg md:text-xl mb-10 max-w-2xl">
        Reggae legends from Falmouth, Jamaica. Six decades of conscious music, spiritual conviction, and international touring.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/history" class="bg-accent text-zinc-950 font-semibold px-8 py-3 rounded hover:bg-accent-light transition-colors">
          Our Story
        </a>
        <a href="/discography" class="border border-white/20 text-white font-semibold px-8 py-3 rounded hover:border-accent hover:text-accent transition-colors">
          Discography
        </a>
      </div>
    </div>
  </section>

  <!-- Live Shows -->
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-16 overflow-hidden">
    <h2 class="font-display text-4xl md:text-5xl tracking-widest uppercase text-white mb-8">Live Shows</h2>
    {tourPhoto && (
      <figure class="float-right ml-8 mb-4 w-2/5">
        <img
          src={`/cdn/${thumbKey(tourPhoto.r2_key)}`}
          alt={tourPhoto.caption || ''}
          class="w-full rounded-lg"
          loading="lazy"
        />
      </figure>
    )}
    {upcomingShows.length > 0 ? (
      <div class="space-y-5">
        {upcomingShows.map((event) => (
          <div class="border-b border-white/10 pb-5">
            <div class="text-accent text-sm font-medium mb-1">{event.date}</div>
            <div class="text-white text-xl font-semibold leading-tight">{event.eventName}</div>
            {event.location && <div class="text-zinc-400 text-sm mt-1">{event.location}</div>}
          </div>
        ))}
      </div>
    ) : (
      <p class="text-zinc-400">No upcoming dates confirmed yet. Check back soon.</p>
    )}
    <a href="/tour" class="inline-block mt-8 text-accent hover:text-accent-light transition-colors font-medium">
      See all dates →
    </a>
  </section>

  <!-- Our Story -->
  <section class="max-w-4xl mx-auto px-6 pt-4 pb-16 overflow-hidden">
    <h2 class="font-display text-4xl md:text-5xl tracking-widest uppercase text-white mb-8">The Story</h2>
    {storyPhoto && (
      <figure class="float-right ml-8 mb-4 w-2/5">
        <img
          src={`/cdn/${thumbKey(storyPhoto.r2_key)}`}
          alt={storyPhoto.caption || ''}
          class="w-full rounded-lg"
          loading="lazy"
        />
      </figure>
    )}
    <p class="text-zinc-300 text-lg leading-relaxed mb-6">
      Norman and Ralston Grant started making music in Falmouth, Jamaica in 1962, singing in Sunday school choirs and beating rhythms on sardine tins. From the Kingston studio circuit and Jamaica's national music festivals, they built their way to a Virgin Records deal in the late 1970s and have been touring the world ever since. Norman moved to the UK in 1986 and has run the band and the Twinkle label from there. Over sixty albums. Their Rastafarian conviction never shifted.
    </p>
    <a href="/history" class="text-accent hover:text-accent-light transition-colors font-medium">
      Read the full history →
    </a>
  </section>

  <!-- Photos -->
  {featuredPhotos.length > 0 && (
    <section class="max-w-4xl mx-auto px-6 pt-4 pb-24">
      <h2 class="font-display text-4xl md:text-5xl tracking-widest uppercase text-white mb-8">Photos</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {featuredPhotos.map((photo) => photo && (
          <a href={`/image/${photo.id}?from=photo`} class="block overflow-hidden rounded-lg group">
            <img
              src={`/cdn/${thumbKey(photo.r2_key)}`}
              alt={photo.caption || ''}
              class="w-full aspect-square object-cover group-hover:opacity-80 transition-opacity"
              loading="lazy"
            />
          </a>
        ))}
      </div>
      <a href="/photos" class="inline-block mt-6 text-accent hover:text-accent-light transition-colors font-medium">
        View all photos →
      </a>
    </section>
  )}

</BaseLayout>
