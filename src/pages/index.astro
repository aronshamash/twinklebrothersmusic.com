---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getImageById } from '../lib/db';
import { fetchTourDates } from '../lib/sheets';
import { thumbKey } from '../lib/thumbKey';

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const env = (Astro.locals as any).runtime?.env;

const featuredPhotoIds = [
  'e7f2f66d-27cf-403e-9f74-d9e59df7654e',
  '07c09655-9ff5-49bc-a261-33f9377dd0db',
  'c46f6b46-8f85-4af3-894c-e4496ddac551',
  'cf34c387-8c3f-49dc-9011-3245087c4ef2',
  '7b1d6f46-d607-42d1-8e55-fbedff4e8c2b',
  'c887cea4-4657-4abf-8769-3d53d7915a68',
];

const featuredPosterIds = [
  '3a8c4737-a339-48e2-b21b-b927a957b7f5',
  '1ee3a28b-2719-4fa4-801e-7d06e678beee',
  '2ea0c9a7-876e-41c0-8cd6-5a74d375339d',
  '23fb2309-0d0c-401e-a6ff-02928b900f5b',
  'f8b10f4d-7d8b-4186-83f2-89389f93e750',
  'e540ae4e-985a-43ff-b9d0-ddc590e17e6f',
];

const [heroPhoto, tourPhoto, storyPhoto, allEvents, ...allFeaturedRaw] = await Promise.all([
  env ? getImageById(env, '2a91e2da-45e4-4d9b-af64-24b7dc182488') : null,
  env ? getImageById(env, '0559bf3e-2158-47d5-9126-948aee9ee894') : null,
  env ? getImageById(env, '0015c01f-b832-482e-865f-2426f3cc7a5d') : null,
  fetchTourDates(),
  ...featuredPhotoIds.map(id => env ? getImageById(env, id) : null),
  ...featuredPosterIds.map(id => env ? getImageById(env, id) : null),
]);

const upcomingShows = allEvents
  .filter((e: { confirmed: string }) => e.confirmed.toUpperCase() === 'Y')
  .slice(0, 3);

const featuredPhotos = allFeaturedRaw.slice(0, featuredPhotoIds.length).filter(Boolean);
const featuredPosters = allFeaturedRaw.slice(featuredPhotoIds.length).filter(Boolean);
---

<BaseLayout title="Twinkle Brothers — Reggae Legends Since 1962">

  <!-- Hero -->
  <section class="flex flex-col pt-0 pb-0">
    <div class="max-w-6xl mx-auto px-0 md:px-6 w-full">
      {heroPhoto && (
        <div class="relative h-screen min-h-[520px] overflow-hidden md:h-[74vh] md:max-h-[820px]">
          <img
            src={`/cdn/${heroPhoto.r2_key}`}
            alt="Norman and Ralston Grant, the Twinkle Brothers"
            fetchpriority="high"
            width="2774"
            height="2646"
            class="absolute inset-0 w-full h-full object-cover object-[35%_22%] md:object-[center_22%]"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to bottom, #09090b 0%, rgba(9,9,11,0.75) 12%, rgba(9,9,11,0.0) 28%, rgba(9,9,11,0.0) 58%, rgba(9,9,11,0.75) 74%, rgba(9,9,11,0.97) 88%, #09090b 100%)"></div>
          <div class="absolute inset-0" style="background: linear-gradient(to right, #09090b 0%, rgba(9,9,11,0.0) 15%, rgba(9,9,11,0.0) 65%, #09090b 100%)"></div>
          <div class="absolute left-0 right-0 bottom-0 px-8 pb-8 text-center">
            <p class="text-xs tracking-[0.3em] uppercase font-semibold text-white mb-3 opacity-90 max-w-[160px] mx-auto md:max-w-none">Est. 1962 · Falmouth, Jamaica</p>
            <h1 class="font-display text-5xl md:text-7xl lg:text-8xl tracking-widest uppercase text-accent leading-none mb-4">
              Twinkle<br>Brothers
            </h1>
            <p class="text-zinc-300 text-base md:text-lg mb-6 max-w-xl mx-auto">
              Reggae legends internationally renowned for their distinctive sound and socially conscious lyrics.
            </p>
            <div class="flex flex-wrap gap-4 justify-center">
              <a href="/history" class="bg-accent text-zinc-950 font-semibold px-8 py-3 rounded hover:bg-accent-light transition-colors">
                Our Story
              </a>
              <a href="/discography" class="border border-white/20 text-white font-semibold px-8 py-3 rounded hover:border-accent hover:text-accent transition-colors">
                Discography
              </a>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Live Shows -->
  <section class="max-w-4xl mx-auto px-6 pt-10 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-[45%_55%] gap-10 items-start">
      <div>
        <h2 class="font-display text-4xl md:text-5xl tracking-widest uppercase text-white mb-8">Live Shows</h2>
        {upcomingShows.length > 0 ? (
          <div class="space-y-5">
            {upcomingShows.map((event) => (
              <div class="border-b border-white/10 pb-5">
                <div class="text-accent text-sm font-medium mb-1">{event.date}</div>
                <div class="text-white text-xl font-semibold leading-tight">{event.eventName}</div>
                {event.location && <div class="text-zinc-400 text-sm mt-1">{event.location}</div>}
              </div>
            ))}
          </div>
        ) : (
          <p class="text-zinc-400">No upcoming dates confirmed yet. Check back soon.</p>
        )}
        <a href="/tour" class="inline-block mt-8 text-accent hover:text-accent-light transition-colors font-medium">
          See all dates →
        </a>
      </div>
      {tourPhoto && (
        <figure class="md:pt-20">
          <img
            src={`/cdn/${tourPhoto.r2_key}`}
            alt={tourPhoto.caption || ''}
            class="w-full rounded-xl object-cover"
            style="max-height: 480px;"
            loading="lazy"
          />
        </figure>
      )}
    </div>
  </section>

  <!-- Our Story -->
  <section class="max-w-4xl mx-auto px-6 pt-4 pb-16 overflow-hidden">
    <h2 class="font-display text-4xl md:text-5xl tracking-widest uppercase text-white mb-8">Our Story</h2>
    <div class="flex flex-col md:block">
      {storyPhoto && (
        <figure class="order-2 w-full mt-6 md:order-none md:float-right md:ml-8 md:mb-4 md:mt-0 md:w-2/5">
          <img
            src={`/cdn/${thumbKey(storyPhoto.r2_key)}`}
            alt={storyPhoto.caption || ''}
            class="w-full rounded-lg"
            loading="lazy"
          />
        </figure>
      )}
      <p class="order-1 text-zinc-300 text-lg leading-relaxed mb-6 md:order-none">
        Norman and Ralston Grant grew up in Falmouth, a small port town on Jamaica's north coast, where they started making music in 1962 with Sunday school choir harmonies and whatever instruments they could piece together, including sardine tins strung with fishing line. They spent years working the Kingston studio circuit alongside the generation of musicians who would go on to shape Jamaican reggae, entered the national Pop and Mento Festival and kept entering until they won, and eventually signed to Virgin Records in the late 1970s. Norman moved to the UK in 1986 and has run the band and the independent Twinkle label from there ever since, releasing records on their own terms while touring regularly across Europe, North America and beyond. Over sixty albums released and more to come, and with Norman continuing to write relavent original lyrics, the music has continued.
      </p>
      <a href="/history" class="order-3 mt-6 text-accent hover:text-accent-light transition-colors font-medium md:order-none md:mt-0">
        Read the full history →
      </a>
    </div>
  </section>

  <!-- Photos -->
  {featuredPhotos.length > 0 && (
    <section class="max-w-4xl mx-auto px-6 pt-4 pb-16">
      <h2 class="font-display text-4xl md:text-5xl tracking-widest uppercase text-white mb-6">Photography</h2>
      <p class="text-zinc-400 text-lg leading-relaxed mb-8">
        We have collected some of the best photography we can find, thanks to all the photographers who documented the band over the years. If you have any you would be happy to share, especially from the early days, please <a href="/contact" class="text-accent hover:text-accent-light transition-colors">get in touch</a>.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {featuredPhotos.map((photo) => photo && (
          <a href={`/image/${photo.id}?from=photo`} class="block overflow-hidden rounded-lg group">
            <img
              src={`/cdn/${thumbKey(photo.r2_key)}`}
              alt={photo.caption || ''}
              class="w-full aspect-square object-cover group-hover:opacity-80 transition-opacity"
              loading="lazy"
            />
          </a>
        ))}
      </div>
      <a href="/photos" class="inline-block mt-6 text-accent hover:text-accent-light transition-colors font-medium">
        View all photos →
      </a>
    </section>
  )}

  <!-- Listen -->
  <section class="max-w-4xl mx-auto px-6 pt-4 pb-16">
    <h2 class="font-display text-4xl md:text-5xl tracking-widest uppercase text-white mb-8">Listen</h2>
    <iframe
      src="https://open.spotify.com/embed/artist/129UGN7LRFtvMzCf0h2Y8s?utm_source=generator&theme=0"
      width="100%"
      height="200"
      allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      loading="lazy"
      style="border-radius: 12px; border: 0;"
    ></iframe>
    <a href="/listen" class="inline-block mt-6 text-accent hover:text-accent-light transition-colors font-medium">
      Further listening →
    </a>
  </section>

  <!-- Posters -->
  {featuredPosters.length > 0 && (
    <section class="max-w-4xl mx-auto px-6 pt-4 pb-24">
      <h2 class="font-display text-4xl md:text-5xl tracking-widest uppercase text-white mb-8">Posters</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {featuredPosters.map((poster) => poster && (
          <a href={`/image/${poster.id}?from=poster`} class="block overflow-hidden rounded-lg group">
            <img
              src={`/cdn/${thumbKey(poster.r2_key)}`}
              alt={poster.caption || ''}
              class="w-full aspect-[3/4] object-cover group-hover:opacity-80 transition-opacity"
              loading="lazy"
            />
          </a>
        ))}
      </div>
      <a href="/posters" class="inline-block mt-6 text-accent hover:text-accent-light transition-colors font-medium">
        View all posters →
      </a>
    </section>
  )}

</BaseLayout>
