---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return [];
}

const { slug } = Astro.params;
---

<BaseLayout title={`${slug} — Twinkle Brothers`}>
  <div class="pt-24 max-w-3xl mx-auto px-6 pb-20">
    <h1 class="font-display text-5xl md:text-7xl tracking-widest uppercase text-white mb-12">{slug}</h1>
    <p class="text-zinc-400">Profile coming soon.</p>
  </div>
</BaseLayout>
