---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getImagesByType, formatImageDate } from '../lib/db';

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const env = (Astro.locals as any).runtime?.env;
const posters = env ? await getImagesByType(env, 'poster') : [];
---

<BaseLayout title="Posters — Twinkle Brothers">
  <style is:global>
    .pswp { --pswp-bg: #09090b; --pswp-icon-color: #fff; --pswp-icon-color-secondary: #71717a; }
    .pswp__img { object-fit: contain !important; }
    .pswp__counter { display: none !important; }
    .pswp-caption-bar {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 0.75rem 1.25rem;
      background: rgba(9,9,11,0.85);
      pointer-events: none;
    }
  </style>

  <div class="pt-24 max-w-6xl mx-auto px-6 pb-20">
    <h1 class="font-display text-5xl md:text-7xl tracking-widest uppercase text-white mb-12">Posters</h1>
    {posters.length === 0 ? (
      <p class="text-zinc-400">Poster archive coming soon.</p>
    ) : (
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {posters.map((poster) => (
          <a
            href={`/image/${poster.id}?from=poster`}
            class="pswp-item group"
            data-pswp-src={`/cdn/${poster.r2_key}`}
            data-caption={poster.caption ?? ''}
            data-date={formatImageDate(poster)}
            data-credit={poster.credit ?? ''}
          >
            <img
              src={`/cdn/${poster.r2_key}`}
              alt={poster.caption || ''}
              class="w-full rounded-lg group-hover:opacity-80 transition-opacity"
              loading="lazy"
            />
            <p class="text-zinc-500 text-xs mt-2">{formatImageDate(poster)}</p>
            {poster.caption && (
              <p class="text-zinc-400 text-sm mt-1 truncate">{poster.caption}</p>
            )}
          </a>
        ))}
      </div>
    )}
  </div>

  <script>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';

    const els = [...document.querySelectorAll<HTMLAnchorElement>('.pswp-item')];

    const items = els.map(el => ({
      src: el.dataset.pswpSrc!,
      width: 1200,
      height: 1600,
      caption: el.dataset.caption ?? '',
      date: el.dataset.date ?? '',
      credit: el.dataset.credit ?? '',
    }));

    els.forEach((el, index) => {
      const img = el.querySelector('img')!;
      const updateSize = () => {
        if (img.naturalWidth > 0) {
          items[index].width = img.naturalWidth;
          items[index].height = img.naturalHeight;
        }
      };
      if (img.complete) updateSize();
      else img.addEventListener('load', updateSize);
    });

    const lightbox = new PhotoSwipeLightbox({
      dataSource: items,
      pswpModule: () => import('photoswipe'),
      bgOpacity: 1,
      padding: { top: 40, bottom: 64, left: 8, right: 8 },
    });

    lightbox.on('uiRegister', () => {
      lightbox.pswp!.ui!.registerElement({
        name: 'caption-bar',
        order: 9,
        isButton: false,
        appendTo: 'root',
        html: '<div class="pswp-caption-bar"><p style="margin:0;color:#e4e4e7;font-size:0.875rem;font-weight:500;line-height:1.4" id="pswp-cap-title"></p><p style="margin:0;color:#71717a;font-size:0.75rem;line-height:1.4" id="pswp-cap-meta"></p></div>',
        onInit(_el: HTMLElement, pswp) {
          pswp.on('change', () => {
            const item = items[pswp.currIndex];
            const titleEl = document.getElementById('pswp-cap-title');
            const metaEl = document.getElementById('pswp-cap-meta');
            if (titleEl) titleEl.textContent = item.caption;
            if (metaEl) metaEl.textContent = [item.date, item.credit].filter(Boolean).join(' · ');
          });
        },
      });
    });

    lightbox.init();

    els.forEach((el, index) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        const img = el.querySelector('img')!;
        if (img.naturalWidth > 0) {
          items[index].width = img.naturalWidth;
          items[index].height = img.naturalHeight;
        }
        lightbox.loadAndOpen(index);
      });
    });
  </script>
</BaseLayout>
