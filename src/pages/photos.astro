---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getImagesByType, formatImageDate } from '../lib/db';

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const env = (Astro.locals as any).runtime?.env;
const photos = env ? await getImagesByType(env, 'photo') : [];
---

<BaseLayout title="Photos — Twinkle Brothers">
  <style>
    .pswp {
      --pswp-bg: #09090b;
      --pswp-icon-color: #ffffff;
      --pswp-icon-color-secondary: #71717a;
    }
    .pswp__img {
      object-fit: contain !important;
    }
    .pswp-caption-bar {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 64px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 0 1.25rem;
      background: rgba(9,9,11,0.85);
      pointer-events: none;
    }
    .pswp-caption-bar p { margin: 0; line-height: 1.4; }
  </style>

  <div class="pt-24 max-w-6xl mx-auto px-6 pb-20">
    <h1 class="font-display text-5xl md:text-7xl tracking-widest uppercase text-white mb-12">Photos</h1>
    {photos.length === 0 ? (
      <p class="text-zinc-400">Photo archive coming soon.</p>
    ) : (
      <div class="columns-2 md:columns-3 lg:columns-4 gap-4">
        {photos.map((photo) => (
          <a
            href={`/image/${photo.id}?from=photo`}
            class="pswp-item block mb-4 break-inside-avoid group"
            data-pswp-src={`/cdn/${photo.r2_key}`}
            data-caption={photo.caption ?? ''}
            data-date={formatImageDate(photo)}
            data-credit={photo.credit ?? ''}
          >
            <img
              src={`/cdn/${photo.r2_key}`}
              alt={photo.caption || ''}
              class="w-full rounded-lg group-hover:opacity-80 transition-opacity"
              loading="lazy"
            />
            {photo.caption && (
              <p class="text-zinc-500 text-xs mt-1 px-1">{formatImageDate(photo)}</p>
            )}
          </a>
        ))}
      </div>
    )}
  </div>

  <script>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';

    const els = [...document.querySelectorAll<HTMLAnchorElement>('.pswp-item')];

    const items = els.map(el => ({
      src: el.dataset.pswpSrc!,
      width: 1600,
      height: 1200,
      caption: el.dataset.caption ?? '',
      date: el.dataset.date ?? '',
      credit: el.dataset.credit ?? '',
    }));

    if (items.length === 0) return;

    // Fix aspect ratios from loaded thumbnails
    els.forEach((el, index) => {
      const img = el.querySelector('img')!;
      const updateSize = () => {
        if (img.naturalWidth > 0) {
          items[index].width = img.naturalWidth;
          items[index].height = img.naturalHeight;
        }
      };
      if (img.complete) updateSize();
      else img.addEventListener('load', updateSize);
    });

    const lightbox = new PhotoSwipeLightbox({
      dataSource: items,
      pswpModule: () => import('photoswipe'),
      bgOpacity: 1,
      padding: { top: 40, bottom: 64, left: 8, right: 8 },
    });

    // Caption bar below image
    lightbox.on('uiRegister', () => {
      lightbox.pswp!.ui!.registerElement({
        name: 'caption-bar',
        order: 9,
        isButton: false,
        appendTo: 'root',
        html: '<div class="pswp-caption-bar"><p style="color:#e4e4e7;font-size:0.875rem;font-weight:500" id="pswp-cap-title"></p><p style="color:#71717a;font-size:0.75rem" id="pswp-cap-meta"></p></div>',
        onInit(_el: HTMLElement, pswp) {
          pswp.on('change', () => {
            const item = items[pswp.currIndex];
            const titleEl = document.getElementById('pswp-cap-title');
            const metaEl = document.getElementById('pswp-cap-meta');
            if (titleEl) titleEl.textContent = item.caption;
            if (metaEl) metaEl.textContent = [item.date, item.credit].filter(Boolean).join(' · ');
          });
        },
      });
    });

    lightbox.init();

    els.forEach((el, index) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        // Re-read dimensions in case image loaded after init
        const img = el.querySelector('img')!;
        if (img.naturalWidth > 0) {
          items[index].width = img.naturalWidth;
          items[index].height = img.naturalHeight;
        }
        lightbox.loadAndOpen(index);
      });
    });
  </script>
</BaseLayout>
