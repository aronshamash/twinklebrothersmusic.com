---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getImagesByType, formatImageDate } from '../lib/db';
import { thumbKey } from '../lib/thumbKey';

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const env = (Astro.locals as any).runtime?.env;
const photos = env ? await getImagesByType(env, 'photo') : [];

const displayPhotos = photos;
---

<BaseLayout title="Photos — Twinkle Brothers">
  <style is:global>
    .pswp { --pswp-bg: #09090b; --pswp-icon-color: #fff; --pswp-icon-color-secondary: #71717a; }
    .pswp__img { object-fit: contain !important; }
    .pswp__counter { display: none !important; }
    #masonry-grid { position: relative; }
    .masonry-item { width: calc(25% - 12px); margin-bottom: 16px; display: block; }
    @media (max-width: 1024px) { .masonry-item { width: calc(33.333% - 11px); } }
    @media (max-width: 640px)  { .masonry-item { width: calc(50% - 8px); } }
  </style>

  <div class="pt-24 max-w-6xl mx-auto px-6 pb-20">
    <h1 class="font-display text-5xl md:text-7xl tracking-widest uppercase text-white mb-12">Photos</h1>
    {photos.length === 0 ? (
      <p class="text-zinc-400">Photo archive coming soon.</p>
    ) : (
      <div id="masonry-grid" class="w-full">
        {displayPhotos.map((photo) => (
          <a
            href={`/image/${photo.id}?from=photo`}
            class="pswp-item masonry-item group"
            data-pswp-src={`/cdn/${photo.r2_key}`}
            data-pswp-width={photo.width ?? ''}
            data-pswp-height={photo.height ?? ''}
            data-caption={photo.caption ?? ''}
            data-date={formatImageDate(photo)}
            data-credit={photo.credit ?? ''}
            data-location={photo.location ?? ''}
          >
            <img
              src={`/cdn/${thumbKey(photo.r2_key)}`}
              alt={photo.caption || ''}
              class="w-full rounded-lg group-hover:opacity-80 transition-opacity"
              loading="lazy"
            />
            {photo.caption && (
              <p class="text-zinc-500 text-xs mt-1 px-1">{formatImageDate(photo)}</p>
            )}
          </a>
        ))}
      </div>
    )}
  </div>

  <script>
    import Masonry from 'masonry-layout';
    import imagesLoaded from 'imagesloaded';

    const grid = document.getElementById('masonry-grid')!;
    const msnry = new Masonry(grid, {
      itemSelector: '.masonry-item',
      columnWidth: '.masonry-item',
      gutter: 16,
      fitWidth: true,
    });

    imagesLoaded(grid).on('progress', () => msnry.layout!());
  </script>

  <script>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';

    const els = [...document.querySelectorAll<HTMLAnchorElement>('.pswp-item')];

    const items = els.map(el => {
      const storedWidth = parseInt(el.dataset.pswpWidth ?? '');
      const storedHeight = parseInt(el.dataset.pswpHeight ?? '');
      return {
        src: el.dataset.pswpSrc!,
        width: storedWidth || 1600,
        height: storedHeight || 1200,
        caption: el.dataset.caption ?? '',
        date: el.dataset.date ?? '',
        credit: el.dataset.credit ?? '',
        location: el.dataset.location ?? '',
        hasDims: !!(storedWidth && storedHeight),
      };
    });

    // For images without stored dimensions, fix aspect ratios from loaded thumbnails
    els.forEach((el, index) => {
      if (items[index].hasDims) return;
      const img = el.querySelector('img')!;
      const updateSize = () => {
        if (img.naturalWidth > 0) {
          const scale = Math.max(1, 1600 / img.naturalWidth);
          items[index].width = Math.round(img.naturalWidth * scale);
          items[index].height = Math.round(img.naturalHeight * scale);
        }
      };
      if (img.complete) updateSize();
      else img.addEventListener('load', updateSize);
    });

    const lightbox = new PhotoSwipeLightbox({
      dataSource: items,
      pswpModule: () => import('photoswipe'),
      bgOpacity: 1,
      padding: { top: 40, bottom: 100, left: 8, right: 8 },
    });

    lightbox.on('uiRegister', function () {
      lightbox.pswp!.ui!.registerElement({
        name: 'share-button',
        order: 8,
        isButton: true,
        appendTo: 'bar',
        html: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>',
        onClick: (_event, _el, pswp) => {
          const item = items[pswp!.currIndex];
          const shareText = `${item.caption ? item.caption + ' — ' : ''}From the Twinkle Brothers archive. Follow @thetwinklebrothers on Instagram.`;
          if (navigator.share) {
            navigator.share({
              title: item.caption || 'Twinkle Brothers Archive',
              text: shareText,
              url: window.location.href,
            }).catch(() => {});
          } else {
            navigator.clipboard.writeText(window.location.href).then(() => {
              const toast = document.createElement('div');
              toast.textContent = 'Link copied';
              toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#f59e0b;color:#09090b;font-size:0.875rem;font-weight:600;padding:8px 16px;border-radius:6px;z-index:9999;pointer-events:none';
              document.body.appendChild(toast);
              setTimeout(() => toast.remove(), 2000);
            });
          }
        },
      });

      lightbox.pswp!.ui!.registerElement({
        name: 'caption',
        order: 9,
        isButton: false,
        appendTo: 'root',
        html: '',
        onInit: (el) => {
          el.style.cssText = [
            'position:fixed',
            'z-index:1500',
            'pointer-events:none',
            'text-align:left',
            'padding:8px 0 0',
          ].join(';');

          const pswp = lightbox.pswp!;

          function positionCaption() {
            const imgEl = pswp.currSlide?.holderElement?.querySelector('img');
            if (!imgEl) return;
            const rect = imgEl.getBoundingClientRect();
            const maxTop = window.innerHeight - el.offsetHeight - 4;
            el.style.top = Math.min(rect.bottom + 8, maxTop) + 'px';
            el.style.left = rect.left + 'px';
            el.style.right = window.innerWidth - rect.right + 'px';
          }

          function updateContent() {
            const item = items[pswp.currIndex];
            const captionLine = item.caption
              ? `<p style="margin:0 0 4px;color:#e4e4e7;font-size:0.875rem;font-weight:500;line-height:1.5">${item.caption}</p>`
              : '';
            const metaLine = (item.date || item.credit || item.location)
              ? `<p style="margin:0;color:#a1a1aa;font-size:0.75rem;line-height:1.5">${[item.date, item.location, item.credit ? 'Credit: ' + item.credit : ''].filter(Boolean).join(' · ')}</p>`
              : '';
            el.innerHTML = captionLine + metaLine;
            el.style.display = (captionLine || metaLine) ? 'block' : 'none';
            requestAnimationFrame(positionCaption);
          }

          pswp.on('change', updateContent);
          pswp.on('zoomPanUpdate', positionCaption);
          window.addEventListener('resize', positionCaption);
          pswp.on('destroy', () => window.removeEventListener('resize', positionCaption));
        },
      });
    });

    // Extract photo IDs from hrefs so the URL stays stable regardless of index
    const photoIds = els.map(el => {
      const match = el.getAttribute('href')?.match(/\/image\/([^?]+)/);
      return match?.[1] ?? null;
    });

    lightbox.on('change', () => {
      const id = photoIds[lightbox.pswp!.currIndex];
      if (id) {
        const url = new URL(window.location.href);
        url.searchParams.set('photo', id);
        history.replaceState({}, '', url.toString());
      }
    });

    lightbox.on('close', () => {
      const url = new URL(window.location.href);
      url.searchParams.delete('photo');
      history.replaceState({}, '', url.toString());
    });

    // Back button closes lightbox instead of navigating away
    let historyPushed = false;
    lightbox.on('beforeOpen', () => {
      history.pushState({ pswp: true }, '');
      historyPushed = true;
    });
    lightbox.on('destroy', () => {
      if (historyPushed) {
        historyPushed = false;
        history.back();
      }
    });
    window.addEventListener('popstate', () => {
      if (lightbox.pswp) {
        historyPushed = false;
        lightbox.pswp.close();
      }
    });

    lightbox.init();

    els.forEach((el, index) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        lightbox.loadAndOpen(index);
      });
    });

    // Deep-link: open directly to a photo if URL has ?photo=<id>
    const linkedPhotoId = new URL(window.location.href).searchParams.get('photo');
    if (linkedPhotoId) {
      const linkedIndex = photoIds.indexOf(linkedPhotoId);
      if (linkedIndex !== -1) {
        lightbox.loadAndOpen(linkedIndex);
      }
    }
  </script>
</BaseLayout>
