---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Twinkle Brothers" description="Book Twinkle Brothers for live performances, festivals, and events.">
  <div class="pt-24 max-w-2xl mx-auto px-6 pb-20">

    <h1 class="font-display text-5xl md:text-7xl tracking-widest uppercase text-white mb-4">Contact</h1>
    <p class="text-zinc-400 mb-12">For booking enquiries, use the form below or email directly at <a href="mailto:bookings@twinklebrothersmusic.com" class="text-accent hover:underline">bookings@twinklebrothersmusic.com</a>.</p>

    <div id="success" class="hidden bg-green-950/50 border border-green-800 rounded-xl px-5 py-6 mb-8">
      <p class="text-green-400 font-medium text-lg mb-1">Message sent</p>
      <p class="text-zinc-400 text-sm">Thanks — we'll be in touch soon.</p>
    </div>

    <div id="error" class="hidden bg-red-950/50 border border-red-900 rounded-xl px-5 py-4 mb-8">
      <p class="text-red-400 font-medium">Something went wrong. Please try again or email us directly.</p>
    </div>

    <form id="contact-form" class="flex flex-col gap-5">

      <div class="grid sm:grid-cols-2 gap-5">
        <div>
          <label class="block text-xs font-medium text-zinc-500 uppercase tracking-wider mb-2">Name *</label>
          <input
            type="text"
            name="name"
            required
            placeholder="Your name"
            class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-3 text-white text-sm placeholder:text-zinc-600 focus:outline-none focus:border-accent/50 transition-colors"
          />
        </div>
        <div>
          <label class="block text-xs font-medium text-zinc-500 uppercase tracking-wider mb-2">Email *</label>
          <input
            type="email"
            name="email"
            required
            placeholder="your@email.com"
            class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-3 text-white text-sm placeholder:text-zinc-600 focus:outline-none focus:border-accent/50 transition-colors"
          />
        </div>
      </div>

      <div>
        <label class="block text-xs font-medium text-zinc-500 uppercase tracking-wider mb-2">Organisation / Promoter</label>
        <input
          type="text"
          name="organisation"
          placeholder="Company or promoter name"
          class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-3 text-white text-sm placeholder:text-zinc-600 focus:outline-none focus:border-accent/50 transition-colors"
        />
      </div>

      <div class="grid sm:grid-cols-2 gap-5">
        <div>
          <label class="block text-xs font-medium text-zinc-500 uppercase tracking-wider mb-2">Event date</label>
          <input
            type="text"
            name="event_date"
            placeholder="DD / MM / YYYY"
            class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-3 text-white text-sm placeholder:text-zinc-600 focus:outline-none focus:border-accent/50 transition-colors"
          />
        </div>
        <div>
          <label class="block text-xs font-medium text-zinc-500 uppercase tracking-wider mb-2">Venue / Location</label>
          <input
            type="text"
            name="venue"
            placeholder="Venue name, city, country"
            class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-3 text-white text-sm placeholder:text-zinc-600 focus:outline-none focus:border-accent/50 transition-colors"
          />
        </div>
      </div>

      <div>
        <label class="block text-xs font-medium text-zinc-500 uppercase tracking-wider mb-2">Message *</label>
        <textarea
          name="message"
          required
          rows="5"
          placeholder="Tell us about the event, expected audience, any other details..."
          class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-3 text-white text-sm placeholder:text-zinc-600 focus:outline-none focus:border-accent/50 transition-colors resize-none"
        ></textarea>
      </div>

      <div class="flex items-center gap-4">
        <button
          type="submit"
          id="submit-btn"
          class="bg-accent text-zinc-950 font-semibold rounded-xl px-8 py-3 text-sm hover:bg-accent-light transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Send Enquiry
        </button>
        <span id="submit-status" class="text-sm text-zinc-500 hidden">Sending...</span>
      </div>

    </form>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const submitStatus = document.getElementById('submit-status') as HTMLSpanElement;
    const successBox = document.getElementById('success') as HTMLDivElement;
    const errorBox = document.getElementById('error') as HTMLDivElement;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      submitBtn.disabled = true;
      submitStatus.classList.remove('hidden');
      errorBox.classList.add('hidden');

      try {
        const response = await fetch('https://formspree.io/f/xbdzvbbg', {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (!response.ok) throw new Error();

        form.classList.add('hidden');
        submitStatus.classList.add('hidden');
        successBox.classList.remove('hidden');
        successBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } catch {
        errorBox.classList.remove('hidden');
        submitBtn.disabled = false;
        submitStatus.classList.add('hidden');
      }
    });
  </script>
</BaseLayout>
