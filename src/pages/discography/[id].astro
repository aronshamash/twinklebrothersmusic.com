---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchReleaseDetail, type DiscogsArtistCredit } from '../../lib/discogs';

const { id } = Astro.params;
const releaseId = Number(id);

if (!releaseId || isNaN(releaseId)) {
  return Astro.redirect('/discography');
}

// Look up list metadata and any preferred release override from D1
const db = Astro.locals.runtime.env.DB;
const [listEntryRow, overrideRow] = await Promise.all([
  db.prepare(
    'SELECT id, master_id, release_type FROM discography_releases WHERE id = ?'
  ).bind(releaseId).first() as Promise<{ id: number; master_id: number | null; release_type: 'master' | 'release' } | null>,
  db.prepare(
    'SELECT preferred_release_id FROM discography_release_overrides WHERE release_id = ?'
  ).bind(releaseId).first() as Promise<{ preferred_release_id: number } | null>,
]);

// If a preferred release is set, use it (always a concrete release, not a master)
const fetchId = overrideRow?.preferred_release_id ?? releaseId;
const fetchType = overrideRow ? 'release' : (listEntryRow?.release_type ?? 'release');

const release = await fetchReleaseDetail(
  fetchId,
  listEntryRow?.master_id ?? undefined,
  fetchType
);

if (!release) {
  return Astro.redirect('/discography');
}

let spotifyUrl: string | null = null;
let youtubeMusicUrl: string | null = null;
try {
  const streamingRow = await db.prepare(
    'SELECT spotify_url, youtube_music_url FROM discography_streaming_links WHERE release_id = ?'
  ).bind(releaseId).first() as { spotify_url: string | null; youtube_music_url: string | null } | null;
  spotifyUrl = streamingRow?.spotify_url ?? null;
  youtubeMusicUrl = streamingRow?.youtube_music_url ?? null;
} catch {
  // streaming links optional — fail silently
}

const primaryImage = release.images.find(img => img.type === 'primary') ?? release.images[0];
const coverUrl = primaryImage?.uri ?? '';

// Filter out heading/index tracks (no position = section divider)
const tracks = release.tracklist.filter(t => t.position !== '');

// Group extra artists by role for display
const musiciansByRole = new Map<string, string[]>();
for (const credit of release.extraartists) {
  const roles = credit.role.split(',').map(r => r.trim()).filter(Boolean);
  for (const role of roles) {
    if (!musiciansByRole.has(role)) musiciansByRole.set(role, []);
    musiciansByRole.get(role)!.push(credit.name.replace(/\s*\(\d+\)$/, ''));
  }
}

// YouTube embeds from videos
function youtubeId(uri: string): string | null {
  const match = uri.match(/(?:v=|youtu\.be\/)([A-Za-z0-9_-]{11})/);
  return match ? match[1] : null;
}
const videos = release.videos
  .map(v => ({ ...v, ytId: youtubeId(v.uri) }))
  .filter(v => v.ytId)
  .slice(0, 1);
---

<BaseLayout title={`${release.title} — Twinkle Brothers`}>
  <div class="pt-24 max-w-5xl mx-auto px-6 pb-20">

    <a href="/discography" class="inline-flex items-center gap-2 text-zinc-500 text-sm hover:text-white transition-colors mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Discography
    </a>

    {/* Hero */}
    <div class="flex flex-col md:flex-row gap-10 mb-16">
      <div class="w-full md:w-80 shrink-0">
        <div class="aspect-square bg-zinc-800 rounded-lg overflow-hidden shadow-2xl">
          {coverUrl
            ? <img src={coverUrl} alt={release.title} class="w-full h-full object-cover" />
            : <div class="w-full h-full flex items-center justify-center text-zinc-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                </svg>
              </div>
          }
        </div>
      </div>

      <div class="flex flex-col justify-start">
        {release.format && (
          <p class="text-zinc-500 text-xs uppercase tracking-[0.2em] mb-3">{release.format}</p>
        )}
        <h1 class="font-display text-4xl md:text-6xl tracking-wide uppercase text-white mb-4 leading-none">{release.title}</h1>
        {release.year > 0 && <p class="text-zinc-400 text-lg mb-6">{release.year}</p>}
        <div class="flex flex-col gap-2 mb-6">
          {release.label && (
            <div class="flex gap-3 text-sm">
              <span class="text-zinc-600 w-16 shrink-0">Label</span>
              <span class="text-zinc-300">{release.label}</span>
            </div>
          )}
        </div>

        {(spotifyUrl || youtubeMusicUrl) && (
          <div class="flex flex-wrap gap-3 mt-2">
            {spotifyUrl && (
              <a href={spotifyUrl} target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-2 px-4 py-2 rounded text-sm font-medium bg-[#1DB954] text-black hover:bg-[#1ed760] transition-colors">
                <svg role="img" viewBox="0 0 24 24" class="w-4 h-4 fill-current" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                </svg>
                Listen on Spotify
              </a>
            )}
            {youtubeMusicUrl && (
              <a href={youtubeMusicUrl} target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-2 px-4 py-2 rounded text-sm font-medium bg-[#FF0000] text-white hover:bg-[#cc0000] transition-colors">
                <svg role="img" viewBox="0 0 24 24" class="w-4 h-4 fill-current" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 0C5.376 0 0 5.376 0 12s5.376 12 12 12 12-5.376 12-12S18.624 0 12 0zm0 19.104c-3.924 0-7.104-3.18-7.104-7.104S8.076 4.896 12 4.896s7.104 3.18 7.104 7.104-3.18 7.104-7.104 7.104zm0-13.332c-3.432 0-6.228 2.796-6.228 6.228S8.568 18.228 12 18.228s6.228-2.796 6.228-6.228S15.432 5.772 12 5.772zM9.684 15.54V8.46L16.2 12l-6.516 3.54z"/>
                </svg>
                YouTube Music
              </a>
            )}
          </div>
        )}

      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-16">

      {/* Tracklist */}
      {tracks.length > 0 && (
        <div>
          <h2 class="text-zinc-400 text-xs tracking-[0.25em] uppercase font-medium mb-6 border-b border-zinc-800 pb-4">Tracklist</h2>
          <div class="divide-y divide-zinc-800/60">
            {tracks.map(track => (
              <div class="flex items-baseline gap-4 py-3">
                <span class="text-zinc-600 text-xs font-mono w-8 shrink-0">{track.position}</span>
                <span class="text-white text-sm flex-1">{track.title}</span>
                {track.duration && <span class="text-zinc-600 text-xs shrink-0">{track.duration}</span>}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Credits + Notes + Videos */}
      <div>
        {musiciansByRole.size > 0 && (
          <div class="mb-10">
            <h2 class="text-zinc-400 text-xs tracking-[0.25em] uppercase font-medium mb-6 border-b border-zinc-800 pb-4">Credits</h2>
            <div class="flex flex-col gap-2">
              {[...musiciansByRole.entries()].map(([role, names]) => (
                <div class="flex gap-3 text-sm">
                  <span class="text-zinc-600 w-28 shrink-0">{role}</span>
                  <span class="text-zinc-300">{names.join(', ')}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        {release.notes && (
          <div class="mb-10">
            <h2 class="text-zinc-400 text-xs tracking-[0.25em] uppercase font-medium mb-6 border-b border-zinc-800 pb-4">Notes</h2>
            <p class="text-zinc-400 text-sm leading-relaxed whitespace-pre-line">{release.notes}</p>
          </div>
        )}

        {videos.length > 0 && (
          <div>
            <h2 class="text-zinc-400 text-xs tracking-[0.25em] uppercase font-medium mb-6 border-b border-zinc-800 pb-4">Videos</h2>
            <div class="flex flex-col gap-6">
              {videos.map(video => (
                <div>
                  <div class="aspect-video rounded-md overflow-hidden bg-zinc-800 mb-2">
                    <iframe
                      src={`https://www.youtube.com/embed/${video.ytId}`}
                      title={video.title}
                      class="w-full h-full"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                      loading="lazy"
                    />
                  </div>
                  <p class="text-zinc-500 text-xs">{video.title}</p>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

    </div>
  </div>
</BaseLayout>
