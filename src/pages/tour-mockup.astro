---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';

const events = [
  { date: '30 May 2026', month: 'May', day: '30', eventName: 'Twinkle Brothers + Trebunie', location: 'Poland' },
  { date: '19 June 2026', month: 'June', day: '19', eventName: 'Reggae Dub Nation', location: 'Limoges, France' },
  { date: '4 July 2026', month: 'July', day: '4', eventName: 'Musique et Terrasses', location: 'Verdun, France' },
  { date: '12 July 2026', month: 'July', day: '12', eventName: 'Summer Roots Festival', location: 'Bristol, UK' },
  { date: '28 August 2026', month: 'August', day: '28', eventName: 'Rototom Sunsplash', location: 'Benicàssim, Spain' },
];

const byMonth = events.reduce((acc, event) => {
  if (!acc[event.month]) acc[event.month] = [];
  acc[event.month].push(event);
  return acc;
}, {} as Record<string, typeof events>);
---

<BaseLayout title="Tour Mockups">
  <div class="pt-24 pb-32 px-6 max-w-4xl mx-auto space-y-32">

    <!-- OPTION 1: Timeline / vertical line -->
    <section>
      <p class="text-zinc-500 text-xs tracking-[0.25em] uppercase mb-2">Option 1</p>
      <h2 class="font-display text-4xl tracking-widest uppercase text-white mb-12">Timeline</h2>
      <div class="relative pl-8 border-l border-zinc-700">
        {events.map((event) => (
          <div class="relative mb-10 last:mb-0">
            <div class="absolute -left-[2.1rem] top-1 w-3 h-3 rounded-full bg-accent border-2 border-zinc-950"></div>
            <div class="text-accent text-xs font-medium tracking-widest uppercase mb-1">{event.date}</div>
            <div class="text-white font-semibold text-lg leading-tight">{event.eventName}</div>
            {event.location && <div class="text-zinc-400 text-sm mt-0.5">{event.location}</div>}
          </div>
        ))}
      </div>
    </section>

    <!-- OPTION 2: Large date treatment -->
    <section>
      <p class="text-zinc-500 text-xs tracking-[0.25em] uppercase mb-2">Option 2</p>
      <h2 class="font-display text-4xl tracking-widest uppercase text-white mb-12">Large Date</h2>
      <div class="space-y-0 divide-y divide-white/5">
        {events.map((event) => (
          <div class="py-8 flex items-center gap-8 group hover:bg-white/2 -mx-4 px-4 transition-colors rounded-lg">
            <div class="shrink-0 text-center w-20">
              <div class="font-display text-5xl text-accent leading-none">{event.day}</div>
              <div class="text-zinc-500 text-xs tracking-widest uppercase mt-1">{event.month}</div>
            </div>
            <div>
              <div class="text-white font-semibold text-xl leading-tight">{event.eventName}</div>
              {event.location && <div class="text-zinc-400 text-sm mt-1">{event.location}</div>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- OPTION 3: Grouped by month -->
    <section>
      <p class="text-zinc-500 text-xs tracking-[0.25em] uppercase mb-2">Option 3</p>
      <h2 class="font-display text-4xl tracking-widest uppercase text-white mb-12">Grouped by Month</h2>
      <div class="space-y-12">
        {Object.entries(byMonth).map(([month, monthEvents]) => (
          <div>
            <h3 class="font-display text-2xl tracking-widest uppercase text-zinc-600 mb-4 border-b border-zinc-800 pb-3">{month}</h3>
            <div class="space-y-3">
              {monthEvents.map((event) => (
                <div class="flex items-center gap-6 py-3">
                  <div class="text-accent font-mono text-sm w-8 shrink-0">{event.day}</div>
                  <div class="flex-1">
                    <span class="text-white font-medium">{event.eventName}</span>
                    {event.location && <span class="text-zinc-500 text-sm ml-3">{event.location}</span>}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- OPTION 4: Full-width rows with muted background text -->
    <section>
      <p class="text-zinc-500 text-xs tracking-[0.25em] uppercase mb-2">Option 4</p>
      <h2 class="font-display text-4xl tracking-widest uppercase text-white mb-12">Background Text</h2>
      <div class="space-y-3">
        {events.map((event) => (
          <div class="relative overflow-hidden rounded-xl bg-zinc-900/60 px-8 py-6 hover:bg-zinc-900 transition-colors group">
            <div class="absolute right-4 top-1/2 -translate-y-1/2 font-display text-8xl text-white/4 leading-none pointer-events-none select-none group-hover:text-white/6 transition-colors">
              {event.location?.split(',')[0]}
            </div>
            <div class="relative flex flex-col md:flex-row md:items-center gap-2 md:gap-8">
              <div class="text-accent font-semibold shrink-0">{event.date}</div>
              <div>
                <div class="text-white font-semibold">{event.eventName}</div>
                {event.location && <div class="text-zinc-400 text-sm">{event.location}</div>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- OPTION 5: Gig poster style -->
    <section>
      <p class="text-zinc-500 text-xs tracking-[0.25em] uppercase mb-2">Option 5</p>
      <h2 class="font-display text-4xl tracking-widest uppercase text-white mb-12">Gig Poster</h2>
      <div class="space-y-px">
        {events.map((event) => (
          <div class="group flex flex-col md:flex-row md:items-baseline gap-1 md:gap-6 py-5 border-b border-white/5 hover:border-accent/20 transition-colors">
            <div class="font-display text-6xl md:text-8xl text-white/10 group-hover:text-accent/20 transition-colors leading-none shrink-0 w-full md:w-36 text-right hidden md:block">
              {event.day}
            </div>
            <div class="flex-1">
              <div class="font-display text-2xl md:text-4xl tracking-wider uppercase text-white leading-tight">{event.eventName}</div>
              <div class="flex items-center gap-3 mt-1">
                <span class="text-accent text-sm font-medium">{event.date}</span>
                {event.location && <span class="text-zinc-500 text-sm">— {event.location}</span>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- OPTION 6: Full-bleed background photo -->
    <section>
      <p class="text-zinc-500 text-xs tracking-[0.25em] uppercase mb-2">Option 6</p>
      <h2 class="font-display text-4xl tracking-widest uppercase text-white mb-12">Full-bleed Background</h2>
    </section>
  </div>

  <!-- Full bleed — outside max-w container -->
  <div class="relative min-h-screen">
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat"
      style="background-image: url('/cdn/ostrada-e253c7a0.jpg')"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-zinc-950/60 via-zinc-950/70 to-zinc-950/90"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 py-32">
      <h1 class="font-display text-5xl md:text-7xl tracking-widest uppercase text-white mb-16">Tour Dates</h1>
      <div class="space-y-px">
        {events.map((event) => (
          <div class="group flex flex-col md:flex-row md:items-baseline gap-1 md:gap-6 py-6 border-b border-white/10 hover:border-accent/30 transition-colors">
            <div class="font-display text-8xl text-white/15 group-hover:text-accent/25 transition-colors leading-none shrink-0 w-36 text-right hidden md:block">
              {event.day}
            </div>
            <div class="flex-1 flex flex-col md:flex-row md:items-baseline md:justify-between gap-3">
              <div>
                <div class="font-display text-2xl md:text-4xl tracking-wider uppercase text-white leading-tight drop-shadow-lg">{event.eventName}</div>
                <div class="flex items-center gap-3 mt-1">
                  <span class="text-accent text-sm font-medium">{event.date}</span>
                  {event.location && <span class="text-zinc-300 text-sm">— {event.location}</span>}
                </div>
              </div>
              <a href="#" class="shrink-0 border border-accent text-accent text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded hover:bg-accent hover:text-zinc-950 transition-colors self-start md:self-auto">
                Tickets
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

</BaseLayout>
