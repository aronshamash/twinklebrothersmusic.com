{
  "name": "twinkle-brothers-site",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "ingest": "tsx scripts/ingest.ts",
    "ingest:local": "tsx scripts/ingest.ts --local",
    "db:migrate": "pnpm wrangler d1 execute DB --local --file migrations/0001_init.sql && pnpm wrangler d1 execute DB --local --file migrations/0002_event_date.sql && pnpm wrangler d1 execute DB --local --file migrations/0003_date_precision.sql && pnpm wrangler d1 execute DB --local --file migrations/0004_discography.sql",
    "sync-discography": "tsx scripts/sync-discography.ts",
    "sync-discography:local": "tsx scripts/sync-discography.ts --local",
    "populate-streaming": "tsx scripts/populate-streaming.ts",
    "populate-streaming:local": "tsx scripts/populate-streaming.ts --local",
    "generate-thumbnails": "tsx scripts/generate-thumbnails.ts",
    "deploy": "astro build && npx wrangler pages deploy dist --project-name twinkle-brothers-site --branch main",
    "ship": "git push && pnpm run deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@astrojs/cloudflare": "^12.3.0",
    "@astrojs/sitemap": "^3.7.1",
    "@aws-sdk/client-s3": "^3.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.4",
    "astro": "^5.7.10",
    "imagesloaded": "^5.0.0",
    "masonry-layout": "^4.2.2",
    "photoswipe": "^5.4.4",
    "tailwindcss": "^4.1.4"
  },
  "packageManager": "pnpm@10.18.3+sha512.bbd16e6d7286fd7e01f6b3c0b3c932cda2965c06a908328f74663f10a9aea51f1129eea615134bf992831b009eabe167ecb7008b597f40ff9bc75946aadfb08d",
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/sharp": "^0.32.0",
    "exifr": "^7.1.3",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.77.0"
  }
}
